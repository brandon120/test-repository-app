# --- Product Forge Coding Agents ---

# Default GitHub repo cloned into each coding sandbox
DEFAULT_REPO_URL=https://github.com/brandon120/test-repository-app
# PRODUCT_FORGE_REPO_URL=https://github.com/your-org/product-forge

# GitHub token with repo read/write for clone, push, and PR creation
GITHUB_TOKEN=

# --- Vercel Sandbox ---
# On Vercel deployments, OIDC auth is automatic after linking the project.
# For local development:
#   npx vercel link
#   npx vercel env pull .env.local
#
# Or set explicit sandbox credentials:
# SANDBOX_VERCEL_TOKEN=
# SANDBOX_VERCEL_TEAM_ID=
# SANDBOX_VERCEL_PROJECT_ID=

# --- Vercel KV (recommended for task persistence across serverless invocations) ---
# Add Vercel KV to the project, then these are populated automatically:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# --- Agent API keys (set the agents you plan to use) ---
# AI_GATEWAY_API_KEY=        # Claude Code + Codex via Vercel AI Gateway
# CURSOR_API_KEY=            # Cursor agent
# GEMINI_API_KEY=            # Gemini CLI
# OPENAI_API_KEY=            # OpenCode / direct OpenAI
# ANTHROPIC_API_KEY=         # OpenCode / direct Anthropic

# Optional
# MAX_SANDBOX_DURATION=60    # minutes
