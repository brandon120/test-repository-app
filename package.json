{
  "name": "product-forge",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env.local --env-file=.env server/index.ts",
    "dev:frontend": "vite",
    "build": "npm run typecheck && vite build && tsc -p tsconfig.server.json",
    "start": "node dist-server/server/index.js",
    "preview": "vite preview",
    "vercel:dev": "vercel dev",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@vercel/functions": "^2.2.2",
    "@vercel/kv": "^3.0.0",
    "@vercel/sandbox": "^2.2.1",
    "express": "^4.21.2",
    "ioredis": "^5.6.1",
    "nanoid": "^5.1.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.4.0",
    "vite": "^6.3.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "dotenv": "^17.3.1",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vercel": "^44.0.0"
  }
}
